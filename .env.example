# ============================================================
# Baseline MLB — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Next.js Frontend (Vercel) ───────────────────────────────
# These are used by the frontend to query Supabase client-side.
# Set these in Vercel Environment Variables as well.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── The Odds API ───────────────────────────────────────────
# Sign up free at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# ── MLB Stats API ─────────────────────────────────────────
# Public API — no key needed
# https://statsapi.mlb.com/api/v1/

# ── Baseball Savant / Statcast ────────────────────────────
# Public API (pybaseball + CSV endpoint) — no key needed
# Rate limit: ~1 request per 3 seconds recommended

# ── Open-Meteo Weather API ───────────────────────────────
# Free, no key required (10,000 requests/day)
# https://open-meteo.com/

# ── Optional / Future ──────────────────────────────────────
# SPORTSRADAR_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# CRON_SECRET=your_cron_secret_here
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
