# FullCountProps Frontend — Environment Variables
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git!

# ============================================================
# SUPABASE (Required for all data display)
# Get these from: https://app.supabase.com/project/_/settings/api
# ============================================================

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (server-side only — NEVER expose in browser)
# Used by webhook handler to update auth.users metadata
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# STRIPE (Required for subscription payments)
# Get these from: https://dashboard.stripe.com/apikeys
# ============================================================

# Stripe secret key (server-side only — NEVER expose in browser)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret
# Get from: https://dashboard.stripe.com/webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for subscription plans
# Create these in: https://dashboard.stripe.com/products → Create product
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# ============================================================
# APP URL (Used for Stripe redirect URLs)
# ============================================================
NEXT_PUBLIC_APP_URL=https://fullcountprops.vercel.app

# ============================================================
# VERCEL DEPLOYMENT NOTES
# ============================================================
# When deploying to Vercel, add ALL variables above as Environment Variables:
# Settings > Environment Variables > Add
#
# Required for frontend (all environments):
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   NEXT_PUBLIC_APP_URL
#
# Required for server-side (Production + Preview):
#   SUPABASE_SERVICE_ROLE_KEY
#   STRIPE_SECRET_KEY
#   STRIPE_WEBHOOK_SECRET
#   STRIPE_PRO_MONTHLY_PRICE_ID
#   STRIPE_PRO_ANNUAL_PRICE_ID
# ============================================================
